# ----------------------------------------------------------------------- #
# Chef configuration — copy to `.env` and fill in. Never commit `.env`.     #
# All variables map to fields in chef/config.py (prefix: CHEF_).             #
# ----------------------------------------------------------------------- #

# --- Child process ------------------------------------------------------ #
CHEF_CHILD_COMMAND=claude
# JSON array of default args for the child command:
CHEF_CHILD_ARGS=[]
CHEF_CHILD_CWD=/workspace
# Regex that identifies a permission prompt in the child's output:
CHEF_PROMPT_PATTERN=\(y/n\)|\(Y/n\)|\[y/N\]|\[Y/n\]|Do you want to proceed\?
CHEF_APPROVE_RESPONSE=y
CHEF_DENY_RESPONSE=n
CHEF_EXPECT_TIMEOUT=30
CHEF_MAX_IDLE_TIMEOUTS=10

# --- Tier 2: LLM evaluator (OpenAI-compatible) -------------------------- #
CHEF_LLM_ENABLED=true
CHEF_LLM_API_KEY=sk-REPLACE_ME
CHEF_LLM_BASE_URL=https://api.openai.com/v1
CHEF_LLM_MODEL=gpt-4o-mini
CHEF_LLM_TIMEOUT=15
CHEF_LLM_MAX_RETRIES=3
CHEF_LLM_BACKOFF_BASE=1.0

# --- Logging ------------------------------------------------------------ #
CHEF_LOG_LEVEL=INFO
CHEF_AUDIT_LOG_PATH=audit.log

# --- Wrapped tool credentials ------------------------------------------- #
# The Claude Code CLI itself reads this (not Chef):
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
