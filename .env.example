# ----------------------------------------------------------------------- #
# Chef configuration — copy to `.env` and fill in. 
# All variables map to fields in chef/config.py (prefix: CHEF_).             #
# ----------------------------------------------------------------------- #

# --- Child process ------------------------------------------------------ #
# The default prompt pattern already recognises Claude Code, Gemini CLI and
# Codex prompts; only set CHEF_PROMPT_PATTERN to override it.
#
# Tool profiles — uncomment ONE block (Claude Code is the default):
#
#   Claude Code (numbered menu: 1 = yes, 2/esc = no)
CHEF_CHILD_COMMAND=claude
CHEF_APPROVE_RESPONSE=1
CHEF_DENY_RESPONSE=2
#
#   Codex CLI (y/n style)
#CHEF_CHILD_COMMAND=codex
#CHEF_APPROVE_RESPONSE=y
#CHEF_DENY_RESPONSE=n
#
#   Gemini CLI (numbered menu: 1 = allow once, 3 = no)
#CHEF_CHILD_COMMAND=gemini
#CHEF_APPROVE_RESPONSE=1
#CHEF_DENY_RESPONSE=3

# JSON array of default args for the child command:
CHEF_CHILD_ARGS=[]
CHEF_CHILD_CWD=/workspace
CHEF_EXPECT_TIMEOUT=30
CHEF_MAX_IDLE_TIMEOUTS=10
# Optional JSON list of extra command-extraction regexes (one capture group
# each), tried before the built-ins:
#CHEF_EXTRA_COMMAND_PATTERNS=["Execute \"([^\"]+)\""]

# --- Tier 2: LLM evaluator (OpenAI-compatible) -------------------------- #
CHEF_LLM_ENABLED=true
CHEF_LLM_API_KEY=sk-REPLACE_ME
CHEF_LLM_BASE_URL=https://api.openai.com/v1
CHEF_LLM_MODEL=gpt-4o-mini
CHEF_LLM_TIMEOUT=15
CHEF_LLM_MAX_RETRIES=3
CHEF_LLM_BACKOFF_BASE=1.0

# --- Logging ------------------------------------------------------------ #
CHEF_LOG_LEVEL=INFO
CHEF_AUDIT_LOG_PATH=audit.log

# --- Wrapped tool credentials ------------------------------------------- #
# Read by the wrapped CLIs themselves (not by Chef). Set the one(s) you use:
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
#OPENAI_API_KEY=sk-REPLACE_ME
#GEMINI_API_KEY=REPLACE_ME
